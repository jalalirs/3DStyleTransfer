FROM pytorch/pytorch:2.4.1-cuda12.4-cudnn9-devel

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git libgl1 libglib2.0-0 libopengl0 libglfw3 \
    && rm -rf /var/lib/apt/lists/*

# Clone MeshUp
RUN git clone https://github.com/threedle/MeshUp.git /opt/MeshUp

# Install MeshUp deps with relaxed versions (upstream pins are broken for py3.11)
RUN pip install --no-cache-dir \
    "diffusers==0.23.0" \
    "transformers==4.36.2" \
    "sentencepiece==0.2.0" \
    "protobuf<5" \
    "tokenizers==0.15.2" \
    "huggingface_hub==0.19.4" \
    tqdm \
    kornia \
    matplotlib \
    cholespy \
    PyGLM \
    scipy \
    trimesh \
    pymeshlab \
    xatlas \
    libigl \
    easydict \
    imageio \
    opencv-python-headless \
    PyOpenGL \
    glfw \
    plyfile \
    vedo \
    cupy-cuda12x \
    tensorboard \
    "imageio[ffmpeg]"

# torch_sparse and torch_scatter need prebuilt wheels for this torch+cuda combo
RUN pip install --no-cache-dir \
    torch-scatter -f https://data.pyg.org/whl/torch-2.4.1+cu124.html && \
    pip install --no-cache-dir \
    torch-sparse -f https://data.pyg.org/whl/torch-2.4.1+cu124.html

# nvdiffrast for differentiable rendering
# Set CUDA arch explicitly — no GPU available during docker build
ENV TORCH_CUDA_ARCH_LIST="8.9"
RUN pip install --no-cache-dir --no-build-isolation git+https://github.com/NVlabs/nvdiffrast.git

# CLIP for text-guided optimization
RUN pip install --no-cache-dir git+https://github.com/openai/CLIP.git

# Server deps
RUN pip install --no-cache-dir fastapi uvicorn python-multipart

COPY gpu-service/server_meshup.py .
COPY gpu-service/meshup_wrapper.py .

EXPOSE 8878

CMD ["python", "server_meshup.py"]
