FROM pytorch/pytorch:2.4.1-cuda12.4-cudnn9-devel

WORKDIR /app

# System deps for rendering and git
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    libgl1 \
    libglib2.0-0 \
    libegl1 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Clone MeshUp at build time
RUN git clone https://github.com/threedle/MeshUp.git /opt/MeshUp

# Install MeshUp requirements
RUN pip install --no-cache-dir -r /opt/MeshUp/requirements.txt

# Install nvdiffrast (needed for differentiable rendering)
RUN pip install --no-cache-dir git+https://github.com/NVlabs/nvdiffrast.git

# Install CLIP
RUN pip install --no-cache-dir git+https://github.com/openai/CLIP.git

# Install server dependencies
RUN pip install --no-cache-dir fastapi uvicorn python-multipart httpx

# Copy server code
COPY gpu-service/server_meshup.py ./server_meshup.py
COPY gpu-service/meshup_wrapper.py ./meshup_wrapper.py

EXPOSE 8878

CMD ["python", "server_meshup.py"]
