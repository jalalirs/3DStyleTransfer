# 3D Style Transfer Platform - Environment Variables

# Replicate API (for SDXL, Flux, TripoSR, InstantMesh)
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Midjourney API (optional, requires a third-party proxy)
MIDJOURNEY_API_URL=
MIDJOURNEY_API_KEY=

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite+aiosqlite:///./style_transfer.db
